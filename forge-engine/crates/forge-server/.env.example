# ──────────────────────────────────────────────────────────────────
# Compose configuration
# ──────────────────────────────────────────────────────────────────

# Set to "parity" to deploy the parity dashboard alongside the server.
# Remove or leave empty to skip the dashboard deployment.
COMPOSE_PROFILES=parity

# ──────────────────────────────────────────────────────────────────
# Parity dashboard — AI analysis (optional)
# ──────────────────────────────────────────────────────────────────

ANALYZE=
OPENAI_API_BASE=
OPENAI_API_KEY=
OPENAI_MODEL=
JAVA_HEAP=512m

# ──────────────────────────────────────────────────────────────────
# GitHub integration (optional — for auto-filing issues)
# ──────────────────────────────────────────────────────────────────

GITHUB_TOKEN=
GITHUB_REPO=

# ──────────────────────────────────────────────────────────────────
# Discord notifications (optional)
# ──────────────────────────────────────────────────────────────────

DISCORD_WEBHOOK_URL=
