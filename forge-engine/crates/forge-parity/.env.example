# ── LLM Backend (pick one) ─────────────────────────────────────
# OpenAI-compatible (works with LiteLLM, llama-server, vLLM, etc.)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com    # or http://localhost:8190 for local
OPENAI_MODEL=gpt-4o-mini                  # model name for analysis
OPENAI_CTX_SIZE=8192                       # optional: max context window

# Anthropic (takes priority over OpenAI if both are set)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Java Harness ──────────────────────────────────────────────
JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-18.jdk/Contents/Home

# ── Discord Notifications (optional) ─────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── MTG Rules (optional, for agentic analysis) ───────────────
# MTG_RULES_PATH=/path/to/MagicCompRules.txt
