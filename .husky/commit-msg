if ! npx --no -- commitlint --edit "$1"; then
  echo ""
  echo "Commit message rejected — must follow Conventional Commits."
  echo ""
  echo "  Format: <type>(<scope>)?: <subject>"
  echo "  Types:  feat, fix, chore, docs, style, refactor, perf, test, build, ci, revert"
  echo "  Subject: lowercase, no trailing period, <= 72 chars"
  echo ""
  echo "Examples:"
  echo "  feat(engine): wire mana cost parser"
  echo "  fix(ui): clamp deck list height on small screens"
  echo "  chore: bump prettier"
  echo ""
  echo "Breaking changes: 'feat!: ...' or include 'BREAKING CHANGE:' footer."
  echo "Docs: https://www.conventionalcommits.org/"
  exit 1
fi
