{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capabilities.schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://archidekt.com/*" },
        { "url": "https://api2.moxfield.com/*" },
        { "url": "https://api.scryfall.com/*" },
        { "url": "https://cards.scryfall.io/*" },
        { "url": "https://svgs.scryfall.io/*" },
        { "url": "https://game.scryfall.io/*" }
      ]
    }
  ]
}
