{
  "productName": "OpenMagic",
  "version": "0.0.0",
  "identifier": "com.forgeweb.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "yarn vite:dev",
    "beforeBuildCommand": "yarn vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenMagic",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../forge/forge-gui/res/cardsfolder": "cardsfolder",
      "../forge/forge-gui/res/tokenscripts": "tokenscripts",
      "../forge/forge-gui/res/editions": "editions",
      "../preset_decks": "preset_decks"
    },
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "iOS": {
      "developmentTeam": "X77VWTYKWV"
    }
  }
}
