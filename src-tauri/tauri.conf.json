{
  "productName": "Manabrew",
  "version": "1.0.2",
  "identifier": "com.manabrew.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "yarn vite:dev",
    "beforeBuildCommand": "yarn tauri:before-build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://play.manabrew.app/tauri.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1OUFFMThDMDA1NzdBNkIKUldScmVsY0FqT0dhMWI2QThlNlNNV1dFamNaOU90MXBZak5nVTd1QlRoUHAwdFBOdnVzN2NFcUQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/forge-runtime": "engine/forge",
      "resources/cardset.rkyv": "cardset.rkyv"
    },
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "iOS": {
      "developmentTeam": "X77VWTYKWV"
    }
  }
}
