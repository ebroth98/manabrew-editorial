---
import { Image } from "astro:assets";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/cormorant-garamond/700.css";
import "@fontsource/alegreya-sans/400.css";
import "@fontsource/alegreya-sans/500.css";
import "@fontsource/alegreya-sans/700.css";
import preset from "../../src/theme";
import logo from "../../../src/assets/manaBrew.png";
import brewery from "../../../public/manabrew_brewery_1.png";
import deckLibrary from "../../../images/screenshots/my-decks.webp";
import deckEditor from "../../../images/screenshots/deck-editor-grid.webp";
import battleground from "../../../images/screenshots/battleground.webp";

const GITHUB = "https://github.com/witchesofthehill/manabrew";
const DISCORD = "https://discord.gg/NqrKpbhtcd";
const WINDOWS_DOWNLOAD = "https://docs.manabrew.app/download-windows/";
const MACOS_DOWNLOAD = "https://docs.manabrew.app/download-macos/";
const DESCRIPTION =
  "An open-source Magic: The Gathering client and rules engine, built around Forge compatibility. Play in your browser or on the desktop.";

const t = preset.dark;
const mana = preset.gameColors;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Manabrew — Magic, by the players, for the players</title>
    <meta name="description" content={DESCRIPTION} />
    <meta property="og:title" content="Manabrew" />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:image" content={new URL(brewery.src, Astro.site)} />
    <meta property="og:url" content={Astro.site} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <header class="nav">
      <a class="wordmark" href="/">
        <Image src={logo} alt="Manabrew" width={64} height={64} />
      </a>
      <nav>
        <a href="https://docs.manabrew.app/">Docs</a>
        <a href={DISCORD}>Discord</a>
        <a href={GITHUB}>GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <Image
          class="hero-art"
          src={brewery}
          alt=""
          widths={[640, 1280, 1920]}
          sizes="100vw"
          loading="eager"
        />
        <div class="hero-veil"></div>
        <div class="hero-inner">
          <p class="kicker reveal">Open-source MTG client · Multiplayer first</p>
          <h1 class="reveal">Magic with friends, minus the friction.</h1>
          <p class="lede reveal">
            Manabrew is a modern client for playing Magic: The Gathering with friends. Available on most platforms and
            <a href="https://github.com/Card-Forge/forge">Forge</a> engine compatible.
          </p>
          <div class="cta-row reveal">
            <a class="btn btn-primary" href="https://play.manabrew.app">Play in your browser</a>
            <a class="btn btn-ghost" href={WINDOWS_DOWNLOAD}>
              <svg class="btn-icon" aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
                <path d="M3 4.9 10.5 3.9v7.4H3V4.9Z"></path>
                <path d="M11.5 3.8 21 2.5v8.8h-9.5V3.8Z"></path>
                <path d="M3 12.3h7.5v7.5L3 18.8v-6.5Z"></path>
                <path d="M11.5 12.3H21v9.2l-9.5-1.3v-7.9Z"></path>
              </svg>
              Download for Windows
            </a>
            <a class="btn btn-ghost" href={MACOS_DOWNLOAD}>
              <svg class="btn-icon" aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
                <path d="M16.4 2c.1 1.1-.3 2.2-1 3-.8.9-1.9 1.5-3 1.4-.1-1 .3-2.1 1-2.9.8-.9 2-1.5 3-1.5Z"></path>
                <path d="M20.5 17.4c-.4.9-.7 1.3-1.2 2.1-.8 1.2-1.9 2.7-3.3 2.7-1.2 0-1.6-.8-3.3-.8s-2.1.8-3.4.8c-1.4 0-2.5-1.4-3.3-2.6-2.3-3.5-2.6-7.6-1.1-9.8 1-1.5 2.6-2.4 4.2-2.4 1.6 0 2.6.8 3.9.8 1.2 0 2-.8 3.8-.8 1.3 0 2.7.7 3.7 1.9-3.2 1.8-2.7 6.4.4 8.1Z"></path>
              </svg>
              Download for macOS
            </a>
            <a class="btn btn-bare" href="https://docs.manabrew.app/">Read the docs →</a>
          </div>
        </div>
      </section>

      <div class="mana-rule" aria-hidden="true">
        <i class="w"></i><i class="u"></i><i class="b"></i><i class="r"></i><i class="g"></i>
      </div>

      <section class="features">
        <article>
          <h2>A game engine that works</h2>
          <p>
            The
            <a href="https://github.com/Card-Forge/forge">Forge engine</a>
            has been developed for 15+ years, and we made manabrew compatible with it.
            We also aim to make it better, with a more modern, official, Manabrew porting.
          </p>
        </article>
        <article>
          <h2>Runs anywhere</h2>
          <p>
            Manabrew ships to browser, desktop, and mobile. No matter where you are, you can play magic with friends.
            No account required.
          </p>
        </article>
        <article>
          <h2>Play together</h2>
          <p>
            Play multiplayer with your friends or against the AI. We support all formats, from standard to commander, up to 4 players.
          </p>
        </article>
        <article>
          <h2>Free as in tavern</h2>
          <p>
            AGPL-3.0+ and developed in the open. Read the code, file an issue,
            port a card — every contribution is brewed in public.
          </p>
        </article>
      </section>

      <section class="gallery">
        <figure class="shot-wide">
          <Image src={deckLibrary} alt="Browsing your deck library in Manabrew" widths={[640, 1280, 1920]} sizes="(max-width: 900px) 100vw, 1080px" />
          <figcaption>Your deck library</figcaption>
        </figure>
        <div class="shot-pair">
          <figure>
            <Image src={deckEditor} alt="The Manabrew deck editor" widths={[480, 960]} sizes="(max-width: 900px) 100vw, 530px" />
            <figcaption>Deck editor</figcaption>
          </figure>
          <figure>
            <Image src={battleground} alt="Manabrew's battleground" widths={[480, 960]} sizes="(max-width: 900px) 100vw, 530px" />
            <figcaption>Battleground</figcaption>
          </figure>
        </div>
      </section>

      <section class="last-call">
        <h2>The cauldron is on.</h2>
        <p>No install, no account — the web client is one click away.</p>
        <a class="btn btn-primary" href="https://play.manabrew.app">Open Manabrew</a>
        <div class="cauldron-scene" aria-hidden="true">
          <div class="ember"></div>
          <div class="cauldron-stage">
            <div class="bubbles" id="cauldron-bubbles"></div>
            <img class="cauldron" src="/cauldronColored.png" alt="" width="760" height="376" loading="lazy" />
          </div>
        </div>
      </section>
    </main>

    <footer>
      <p>
        Manabrew is unofficial fan software, not affiliated with, endorsed by, or
        sponsored by Wizards of the Coast LLC or the Forge project. Magic: The
        Gathering and related marks are property of Wizards of the Coast LLC.
        Card images are not shipped by this project.
      </p>
      <p class="foot-links">
        <a href={GITHUB}>GitHub</a> · <a href={DISCORD}>Discord</a> ·
        <a href="https://docs.manabrew.app/">Documentation</a> ·
        <a href={`${GITHUB}/blob/main/LICENSE.md`}>AGPL-3.0-or-later</a>
      </p>
    </footer>
    <script>
      // ── Bubble tuning knobs ──────────────────────────────────────────
      const BUBBLES = {
        sizeMin: 18, // smallest bubble diameter (px)
        sizeMax: 24, // largest bubble diameter (px)
        spreadStart: 0, // left edge of spawn band (% across the mouth)
        spreadEnd: 100, // right edge of spawn band (%)
        liftMin: 65, // shortest rise height (px)
        liftMax: 75, // tallest rise height (px)
        durMin: 7.5, // fastest rise time (s) — bigger = slower
        durMax: 10.5, // slowest rise time (s)
        gapMin: 900, // shortest pause between bubbles (ms) — bigger = fewer
        gapMax: 901, // longest pause between bubbles (ms)
        warmthMin: 0, // color mix per bubble: 0 = full purple
        warmthMax: 0.5, // 1 = full orange (range spreads bubbles across both)
      };
      // Fade timing lives in the `@keyframes bubble-rise` rule (the `70%` stop
      // is where the fade-out begins — raise it to fade later/higher).
      // ─────────────────────────────────────────────────────────────────

      const layer = document.getElementById("cauldron-bubbles");
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");
      const rand = (min: number, max: number) => min + Math.random() * (max - min);

      function spawnBubble() {
        const b = document.createElement("span");
        b.className = "bubble";
        const size = rand(BUBBLES.sizeMin, BUBBLES.sizeMax);
        b.style.width = size + "px";
        b.style.height = size + "px";
        b.style.left = rand(BUBBLES.spreadStart, BUBBLES.spreadEnd) + "%";
        b.style.setProperty("--lift", rand(BUBBLES.liftMin, BUBBLES.liftMax) + "px");
        b.style.setProperty("--dur", rand(BUBBLES.durMin, BUBBLES.durMax).toFixed(2) + "s");
        b.style.setProperty("--mix", rand(BUBBLES.warmthMin, BUBBLES.warmthMax).toFixed(2));
        b.addEventListener("animationend", () => b.remove());
        if (layer) {
          layer.appendChild(b);
        }
      }

      let timer;
      function loop() {
        if (document.visibilityState === "visible") spawnBubble();
        timer = window.setTimeout(loop, rand(BUBBLES.gapMin, BUBBLES.gapMax));
      }

      if (layer && !reduced.matches) loop();
      reduced.addEventListener("change", (e) => {
        if (e.matches) {
          window.clearTimeout(timer);
        } else {
          loop();
        }
      });
    </script>
  </body>
</html>

<style
  define:vars={{
    background: t.background,
    card: t.card,
    accent: t.accent,
    border: t.border,
    foreground: t.foreground,
    "muted-foreground": t["muted-foreground"],
    primary: t.primary,
    "primary-foreground": t["primary-foreground"],
    ring: t.ring,
    "mana-w": mana["mana.W"],
    "mana-u": mana["mana.U"],
    "mana-b": mana["mana.B"],
    "mana-r": mana["mana.R"],
    "mana-g": mana["mana.G"],
  }}
>
  :root {
    --font-display: "Cormorant Garamond", georgia, serif;
    --font-body: "Alegreya Sans", system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--background);
    color: var(--foreground);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: var(--primary);
  }

  .nav {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    padding: 1.1rem clamp(1rem, 4vw, 3rem);
  }

  .wordmark {
    display: flex;
    align-items: center;
  }

  .wordmark img {
    height: 3rem;
    width: auto;
  }

  .nav nav {
    display: flex;
    gap: clamp(0.9rem, 3vw, 1.8rem);
  }

  .nav nav a {
    color: var(--foreground);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.8rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.9);
  }

  .nav nav a:hover {
    color: var(--primary);
  }

  .hero {
    position: relative;
    min-height: clamp(540px, 92svh, 860px);
    display: grid;
    align-items: end;
    overflow: hidden;
  }

  .hero-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    /* Same haze as the app's welcome screen (AppInitGate: opacity-50 blur-md) */
    opacity: 0.5;
    filter: blur(12px);
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--background) 55%, transparent) 0%,
        color-mix(in srgb, var(--background) 15%, transparent) 35%,
        color-mix(in srgb, var(--background) 82%, transparent) 75%,
        var(--background) 100%
      ),
      radial-gradient(120% 60% at 50% 100%, color-mix(in srgb, var(--background) 75%, transparent) 0%, transparent 60%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: min(64rem, 100%);
    margin-inline: auto;
    padding: 0 clamp(1rem, 4vw, 3rem) clamp(5.5rem, 16vh, 9rem);
  }

  .kicker {
    margin: 0 0 0.6rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary);
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 8vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.85);
  }

  .lede {
    max-width: 36rem;
    margin: 1.1rem 0 1.8rem;
    font-size: clamp(1.05rem, 2.4vw, 1.25rem);
    color: var(--foreground);
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.9);
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.78rem 1.5rem;
    border-radius: 4px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition:
      transform 140ms ease,
      box-shadow 140ms ease,
      background-color 140ms ease;
  }

  .btn-icon {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
    display: block;
    fill: var(--foreground);
  }

  .btn-primary {
    background: linear-gradient(180deg, var(--primary), var(--ring));
    color: var(--primary-foreground);
    box-shadow: 0 0 24px color-mix(in srgb, var(--primary) 35%, transparent);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 34px color-mix(in srgb, var(--primary) 55%, transparent);
  }

  .btn-ghost {
    border: 1px solid var(--ring);
    color: var(--foreground);
    background: color-mix(in srgb, var(--background) 45%, transparent);
  }

  .btn-ghost:hover {
    background: color-mix(in srgb, var(--border) 60%, transparent);
  }

  .btn-bare {
    padding-inline: 0.3rem;
    color: var(--muted-foreground);
  }

  .btn-bare:hover {
    color: var(--primary);
  }

  .mana-rule {
    display: flex;
    justify-content: center;
    gap: 1.6rem;
    padding: clamp(2rem, 5vh, 3rem) 1rem;
  }

  .mana-rule i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    animation: simmer 3.2s ease-in-out infinite;
  }

  .mana-rule .w { background: var(--mana-w); box-shadow: 0 0 12px var(--mana-w); }
  .mana-rule .u { background: var(--mana-u); box-shadow: 0 0 12px var(--mana-u); animation-delay: 0.3s; }
  .mana-rule .b { background: var(--mana-b); box-shadow: 0 0 12px var(--mana-b); animation-delay: 0.6s; }
  .mana-rule .r { background: var(--mana-r); box-shadow: 0 0 12px var(--mana-r); animation-delay: 0.9s; }
  .mana-rule .g { background: var(--mana-g); box-shadow: 0 0 12px var(--mana-g); animation-delay: 1.2s; }

  .features {
    width: min(70rem, 100%);
    margin-inline: auto;
    padding: 0 clamp(1rem, 4vw, 3rem) clamp(2.5rem, 6vh, 4.5rem);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .features article {
    background: linear-gradient(160deg, var(--card), var(--accent));
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.4rem 1.4rem 1.2rem;
  }

  .features h2 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.45rem;
    color: var(--primary);
  }

  .features p {
    margin: 0;
    color: var(--muted-foreground);
  }

  .gallery {
    width: min(70rem, 100%);
    margin-inline: auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: grid;
    gap: 1rem;
  }

  .gallery figure {
    margin: 0;
  }

  .gallery img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .gallery figcaption {
    padding-top: 0.45rem;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .shot-pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .last-call {
    position: relative;
    text-align: center;
    padding: clamp(3.5rem, 10vh, 6.5rem) 1.5rem 0;
  }

  .last-call h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 6vw, 3.2rem);
  }

  .last-call p {
    margin: 0 0 1.6rem;
    color: var(--muted-foreground);
  }

  footer {
    position: relative;
    z-index: 3;
    background: var(--background);
    border-top: 1px solid var(--border);
    padding: 2rem clamp(1rem, 4vw, 3rem) 2.6rem;
    text-align: center;
  }

  footer p {
    max-width: 46rem;
    margin: 0 auto 1rem;
    font-size: 0.85rem;
    color: var(--muted-foreground);
  }

  .foot-links a {
    color: var(--foreground);
  }

  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      animation: rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }

    .reveal:nth-child(2) { animation-delay: 90ms; }
    .reveal:nth-child(3) { animation-delay: 180ms; }
    .reveal:nth-child(4) { animation-delay: 280ms; }
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes simmer {
    0%, 100% { transform: translateY(0); opacity: 0.75; }
    50% { transform: translateY(-4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mana-rule i {
      animation: none;
    }
  }
</style>

<style is:global>
  /* Global (unscoped) so the JS-spawned .bubble elements pick up these rules. */

  /* ── Bubble colors — each bubble blends between these two sets via --mix
        (0 = full purple, 1 = full orange; set per-bubble in the script). ── */
  :root {
    --bubble-purple-core: rgba(245, 200, 255, 0.98);
    --bubble-purple-mid: rgba(206, 104, 224, 0.96);
    --bubble-purple-edge: rgba(126, 56, 190, 0.95);
    --bubble-purple-glow: rgba(190, 96, 240, 0.8);

    --bubble-orange-core: rgba(255, 224, 150, 0.98);
    --bubble-orange-mid: rgba(255, 150, 48, 0.96);
    --bubble-orange-edge: rgba(218, 92, 18, 0.95);
    --bubble-orange-glow: rgba(255, 140, 40, 0.85);
  }
  /* ─────────────────────────────────────────────────────────────────── */

  .last-call::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      62% 86% at 50% 100%,
      rgba(255, 150, 36, 0.38) 0%,
      rgba(255, 96, 20, 0.14) 40%,
      transparent 72%
    );
    transform-origin: 50% 100%;
    will-change: opacity, transform;
    animation: ember-breathe 3.6s ease-in-out infinite;
  }

  .cauldron-scene {
    position: relative;
    z-index: 0;
    width: min(520px, 82vw);
    margin: clamp(1.8rem, 6vh, 3.4rem) auto -3.25rem;
  }

  .cauldron-stage {
    position: relative;
    width: 100%;
  }

  .cauldron {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
  }

  .ember {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    width: 96%;
    height: 62%;
    transform: translateX(-50%);
    background:
      radial-gradient(ellipse 62% 70% at 50% 80%, rgba(255, 184, 56, 0.95) 0%, rgba(255, 120, 24, 0.6) 36%, rgba(255, 70, 10, 0) 72%),
      radial-gradient(ellipse 38% 50% at 50% 86%, rgba(255, 234, 150, 0.95) 0%, rgba(255, 160, 40, 0) 62%);
    filter: blur(14px);
    z-index: 0;
    will-change: opacity, transform;
    animation: fire-flicker 2.6s ease-in-out infinite;
  }

  .bubbles {
    position: absolute;
    left: 28%;
    right: 28%;
    top: -14%;
    bottom: 68%;
    z-index: 2;
    pointer-events: none;
  }

  .bubble {
    --mix: 0;
    position: absolute;
    bottom: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at 32% 28%,
      color-mix(in srgb, var(--bubble-orange-core) calc(var(--mix) * 100%), var(--bubble-purple-core)) 0%,
      color-mix(in srgb, var(--bubble-orange-mid) calc(var(--mix) * 100%), var(--bubble-purple-mid)) 45%,
      color-mix(in srgb, var(--bubble-orange-edge) calc(var(--mix) * 100%), var(--bubble-purple-edge)) 100%
    );
    box-shadow:
      0 0 14px color-mix(in srgb, var(--bubble-orange-glow) calc(var(--mix) * 100%), var(--bubble-purple-glow)),
      inset 0 0 6px rgba(255, 246, 230, 0.7);
    will-change: transform, opacity;
    animation: bubble-rise var(--dur, 4s) linear forwards;
  }

  @keyframes fire-flicker {
    0%, 100% {
      opacity: 0.78;
      transform: translateX(-50%) scaleY(1);
