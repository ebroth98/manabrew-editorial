{
  "grammars": [
    {
      "name": "forge-card-script",
      "camelcase": "ForgeCardScript",
      "scope": "source.forge-card-script",
      "path": ".",
      "file-types": ["txt"],
      "injection-regex": "forge"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Forge Card Script DSL",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-forge-card-script"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
