# Builds the Tauri web frontend (wasm + React) as a static site and
# serves it directly via Caddy. Caddy also reverse-proxies the multiplayer
# relay (manabrew-server) and parity dashboard, terminates Let's Encrypt TLS
# for all three public hostnames, and sets the COOP/COEP/CORP headers
# SharedArrayBuffer requires.
#
# Build context: repo root (needs manabrew-rs/, src/, scripts/,
# forge/forge-gui/res/cardsfolder/, public/preset_decks/, package.json, vite.config.ts)

# --- Ironsmith WASM builder: compiles the trusted-runtime engine to WASM in a
# dedicated stage so this heavy, network-fetching build (Scryfall bulk sync +
# registry + wasm-pack) caches on the ironsmith sources alone and is NOT
# invalidated by manabrew src/ changes. The `ironsmith` submodule is
# `update = none`, so the caller (deploy.sh / docker-images.yml) force-checks it
# out before the build; when it is absent this stage emits an empty pkg and the
# runtime ships dark (scripts/sync-ironsmith-wasm.mjs installs the stub, and the
# lobby tile stays hidden — see src/game/runtimeRegistry.ts). .dockerignore
# trims the copied tree to just the submodule sources.
FROM rust:1.88-slim AS ironsmith
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates build-essential pkg-config libssl-dev python3 git && \
    rm -rf /var/lib/apt/lists/*
RUN rustup target add wasm32-unknown-unknown && \
    cargo install wasm-pack --version 0.13.1 --locked
WORKDIR /ironsmith
COPY ironsmith/ ./
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    if [ -f rebuild-wasm.sh ]; then \
        ./rebuild-wasm.sh; \
    else \
        echo "ironsmith submodule not checked out; emitting empty pkg (runtime ships dark)"; \
        mkdir -p pkg; \
    fi

# --- Base: Rust + Node toolchain shared by the planner and builder stages ---
FROM rust:1.88-slim AS base

# Install Node.js 20 and build tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates build-essential pkg-config libssl-dev && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install wasm32 target and wasm-pack (pinned; newer versions track latest rustc)
RUN rustup target add wasm32-unknown-unknown && \
    cargo install wasm-pack --version 0.13.1 --locked && \
    cargo install cargo-chef --locked

WORKDIR /build

# --- Planner: cargo-chef dependency recipe from the manifests alone ---
# See manabrew-server's Dockerfile for why chef. This build is the ~1h one
# that gates the early web deploy, so its dependency layers matter most.
FROM base AS planner
COPY Cargo.toml Cargo.lock ./
COPY .cargo/ ./.cargo/
COPY src-tauri/ ./src-tauri/
COPY manabrew-rs/ ./manabrew-rs/
COPY tree-sitter-forge-card-script/ ./tree-sitter-forge-card-script/
COPY xtask/ ./xtask/
RUN cargo chef prepare --recipe-path recipe.json

# --- Builder: Rust + Node to build WASM and bundle the Vite app ---
FROM base AS builder

# Install JS deps first for layer caching
COPY package.json yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile

# Cook the dependency graph for each compile `yarn build:web` performs: the
# native cardset-archive builder, the wasm engine, and the (debug) xtask that
# drives gen:types. Only a real dependency change invalidates these layers.
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json -p forge-cardset-archive --features build
RUN cargo chef cook --release --recipe-path recipe.json --target wasm32-unknown-unknown -p wasm
RUN cargo chef cook --recipe-path recipe.json -p xtask

# Copy the rest of the sources needed for the web build
COPY Cargo.toml Cargo.lock ./
# The `xtask` cargo alias (used by `build:web`'s gen:types step) lives in
# .cargo/config.toml — without it `cargo xtask` fails with "no such command".
COPY .cargo/ ./.cargo/
# src-tauri is a workspace member; cargo metadata needs its manifest to resolve
COPY src-tauri/ ./src-tauri/
COPY manabrew-rs/ ./manabrew-rs/
# tree-sitter-forge-card-script is also a workspace member (declared at the
# repo root, not under manabrew-engine/) so cargo metadata fails without it.
COPY tree-sitter-forge-card-script/ ./tree-sitter-forge-card-script/
COPY xtask/ ./xtask/
COPY scripts/ ./scripts/
COPY src/ ./src/
COPY public/ ./public/
# ops/manifest.json is read by vite.config.ts to stamp the app version.
COPY index.html tsconfig*.json vite.config.ts ./
COPY ops/manifest.json ./ops/manifest.json
# These four dirs feed the rkyv cardset archive build — keep in sync with the
# source list in `scripts/build-wasm.mjs`. Omitting `editions`/`blockdata` is
# silent: the archive builder emits an empty editions vec for a missing dir, so
# the web build still succeeds but ships with no set data and every limited
# draft fails with "unknown set". Preset decks are served as-is.
COPY forge/forge-gui/res/cardsfolder/ ./forge/forge-gui/res/cardsfolder/
COPY forge/forge-gui/res/tokenscripts/ ./forge/forge-gui/res/tokenscripts/
COPY forge/forge-gui/res/editions/ ./forge/forge-gui/res/editions/
COPY forge/forge-gui/res/blockdata/ ./forge/forge-gui/res/blockdata/
COPY public/preset_decks/ ./public/preset_decks/
# Ironsmith trusted-runtime WASM, built in the `ironsmith` stage above.
# `yarn sync:ironsmith` (inside build:web) copies it into the bundle, or installs
# a stub when the pkg is empty (submodule not checked out) so the runtime ships
# dark. Copied from the stage — not the host context — so a local `docker build`
# never needs the wasm prebuilt.
COPY --from=ironsmith /ironsmith/pkg/ ./ironsmith/pkg/

# Production build defaults — the prod compose passes these as build args
# so the static bundle bakes in the public relay endpoint. Dev builds (yarn
# dev) leave them unset and fall back to localhost:9443.
ARG VITE_RELAY_HOST=
ARG VITE_RELAY_PORT=
ARG VITE_RELAY_PASSWORD=
ARG VITE_MANAGED_RELAY=
ARG VITE_SCRYFALL_SYMBOL_BASE=
ARG VITE_HOSTED_AI_ENABLED=
ARG VITE_HUB_API_URL=
ENV VITE_RELAY_HOST=${VITE_RELAY_HOST}
ENV VITE_RELAY_PORT=${VITE_RELAY_PORT}
ENV VITE_RELAY_PASSWORD=${VITE_RELAY_PASSWORD}
ENV VITE_MANAGED_RELAY=${VITE_MANAGED_RELAY}
ENV VITE_SCRYFALL_SYMBOL_BASE=${VITE_SCRYFALL_SYMBOL_BASE}
ENV VITE_HOSTED_AI_ENABLED=${VITE_HOSTED_AI_ENABLED}
ENV VITE_HUB_API_URL=${VITE_HUB_API_URL}

# Build WASM + Vite bundle (outputs to dist/). Dependencies come precompiled
# from the chef cook layers above (cache mounts would shadow them and don't
# survive CI runners anyway), so this compiles workspace crates only.
RUN yarn build:web

# --- Website: landing page (manabrew.app) + docs (docs.manabrew.app),
# Astro + Starlight, two builds out of one package ---
FROM node:20-slim AS website

# The site imports assets and theme data via relative paths that escape
# website/ (../images, ../public, ../src) — keep the same directory layout here.
WORKDIR /repo/website
COPY website/package.json website/yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile
COPY images/ /repo/images/
COPY public/manabrew_brewery_1.png /repo/public/manabrew_brewery_1.png
COPY src/themes/ /repo/src/themes/
COPY src/assets/manaBrew.png /repo/src/assets/manaBrew.png
COPY website/ ./
RUN yarn build

# --- Runtime: Caddy serves the built dist directly, reverse-proxies the
# relay + parity hostnames, and terminates Let's Encrypt TLS for all
# three. ops/Caddyfile is mounted in via compose so config changes don't
# require a rebuild. ---
FROM caddy:2-alpine

COPY --from=builder /build/dist/ /srv/manabrew/
COPY --from=website /repo/website/dist/landing/ /srv/landing/
COPY --from=website /repo/website/dist/docs/ /srv/docs/

# Standalone defaults so `docker run` works with no mounted config: a :80
# Caddyfile with the isolation headers, plus an entrypoint that writes the
# runtime relay config (config.js) from RELAY_* env before starting Caddy. The
# production compose mounts ops/Caddyfile over this default; the entrypoint runs
# either way and leaves config.js empty when RELAY_HOST is unset.
COPY ops/standalone.Caddyfile /etc/caddy/Caddyfile
COPY ops/web-entrypoint.sh /usr/local/bin/manabrew-entrypoint.sh
RUN chmod +x /usr/local/bin/manabrew-entrypoint.sh

EXPOSE 80 443

ENTRYPOINT ["manabrew-entrypoint.sh"]
