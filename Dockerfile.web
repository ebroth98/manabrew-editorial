# Builds the Tauri web frontend (forge-wasm + React) as a static site
# served by nginx. Requires COOP/COEP headers for SharedArrayBuffer
# (used by the WASM game engine worker with Atomics.wait).
#
# Build context: repo root (needs forge-engine/, src/, scripts/,
# forge/forge-gui/res/cardsfolder/, preset_decks/, package.json, vite.config.ts)

# --- Builder: Rust + Node to build WASM and bundle the Vite app ---
FROM rust:1.88-slim AS builder

# Install Node.js 20 and build tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates build-essential pkg-config libssl-dev && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install wasm32 target and wasm-pack (pinned; newer versions track latest rustc)
RUN rustup target add wasm32-unknown-unknown && \
    cargo install wasm-pack --version 0.13.1 --locked

WORKDIR /build

# Install JS deps first for layer caching
COPY package.json yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile

# Copy the rest of the sources needed for the web build
COPY Cargo.toml Cargo.lock ./
# src-tauri is a workspace member; cargo metadata needs its manifest to resolve
COPY src-tauri/ ./src-tauri/
COPY forge-engine/ ./forge-engine/
# tree-sitter-forge-card-script is also a workspace member (declared at the
# repo root, not under forge-engine/) so cargo metadata fails without it.
COPY tree-sitter-forge-card-script/ ./tree-sitter-forge-card-script/
COPY scripts/ ./scripts/
COPY src/ ./src/
COPY public/ ./public/
COPY index.html tsconfig*.json vite.config.ts ./
# Card + token scripts + preset decks consumed by bundle-cards.mjs
COPY forge/forge-gui/res/cardsfolder/ ./forge/forge-gui/res/cardsfolder/
COPY forge/forge-gui/res/tokenscripts/ ./forge/forge-gui/res/tokenscripts/
COPY preset_decks/ ./preset_decks/

# Build WASM + Vite bundle (outputs to dist/)
RUN yarn build:web

# --- Runtime: nginx serving the static bundle. Sets COOP/COEP at the origin
# so the app becomes cross-origin-isolated (required for SharedArrayBuffer) ---
FROM nginx:1.27-alpine

RUN apk add --no-cache openssl && \
    mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 3650 \
        -newkey rsa:2048 \
        -keyout /etc/nginx/ssl/selfsigned.key \
        -out /etc/nginx/ssl/selfsigned.crt \
        -subj "/CN=openmagic"

COPY nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /build/dist/ /usr/share/nginx/html/

EXPOSE 80 443
