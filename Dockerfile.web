# Builds the Tauri web frontend (wasm + React) as a static site and
# serves it directly via Caddy. Caddy also reverse-proxies the multiplayer
# relay (manabrew-server) and parity dashboard, terminates Let's Encrypt TLS
# for all three public hostnames, and sets the COOP/COEP/CORP headers
# SharedArrayBuffer requires.
#
# Build context: repo root (needs manabrew-rs/, src/, scripts/,
# forge/forge-gui/res/cardsfolder/, public/preset_decks/, package.json, vite.config.ts)

# --- Builder: Rust + Node to build WASM and bundle the Vite app ---
FROM rust:1.88-slim AS builder

# Install Node.js 20 and build tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl ca-certificates build-essential pkg-config libssl-dev && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install wasm32 target and wasm-pack (pinned; newer versions track latest rustc)
RUN rustup target add wasm32-unknown-unknown && \
    cargo install wasm-pack --version 0.13.1 --locked

WORKDIR /build

# Install JS deps first for layer caching
COPY package.json yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile

# Copy the rest of the sources needed for the web build
COPY Cargo.toml Cargo.lock ./
# src-tauri is a workspace member; cargo metadata needs its manifest to resolve
COPY src-tauri/ ./src-tauri/
COPY manabrew-rs/ ./manabrew-rs/
# tree-sitter-forge-card-script is also a workspace member (declared at the
# repo root, not under manabrew-engine/) so cargo metadata fails without it.
COPY tree-sitter-forge-card-script/ ./tree-sitter-forge-card-script/
COPY scripts/ ./scripts/
COPY src/ ./src/
COPY public/ ./public/
# .release-please-manifest.json is read by vite.config.ts to stamp the app version.
COPY index.html tsconfig*.json vite.config.ts .release-please-manifest.json ./
# These four dirs feed the rkyv cardset archive build — keep in sync with the
# source list in `scripts/build-wasm.mjs`. Omitting `editions`/`blockdata` is
# silent: the archive builder emits an empty editions vec for a missing dir, so
# the web build still succeeds but ships with no set data and every limited
# draft fails with "unknown set". Preset decks are served as-is.
COPY forge/forge-gui/res/cardsfolder/ ./forge/forge-gui/res/cardsfolder/
COPY forge/forge-gui/res/tokenscripts/ ./forge/forge-gui/res/tokenscripts/
COPY forge/forge-gui/res/editions/ ./forge/forge-gui/res/editions/
COPY forge/forge-gui/res/blockdata/ ./forge/forge-gui/res/blockdata/
COPY public/preset_decks/ ./public/preset_decks/

# Production build defaults — the prod compose passes these as build args
# so the static bundle bakes in the public relay endpoint. Dev builds (yarn
# dev) leave them unset and fall back to localhost:9443.
ARG VITE_RELAY_HOST=
ARG VITE_RELAY_PORT=
ARG VITE_RELAY_PASSWORD=
ARG VITE_MANAGED_RELAY=
ARG VITE_SCRYFALL_SYMBOL_BASE=
ARG VITE_HOSTED_AI_ENABLED=
ENV VITE_RELAY_HOST=${VITE_RELAY_HOST}
ENV VITE_RELAY_PORT=${VITE_RELAY_PORT}
ENV VITE_RELAY_PASSWORD=${VITE_RELAY_PASSWORD}
ENV VITE_MANAGED_RELAY=${VITE_MANAGED_RELAY}
ENV VITE_SCRYFALL_SYMBOL_BASE=${VITE_SCRYFALL_SYMBOL_BASE}
ENV VITE_HOSTED_AI_ENABLED=${VITE_HOSTED_AI_ENABLED}

# Build WASM + Vite bundle (outputs to dist/).
#
# BuildKit cache mounts make src/-only changes ~5-10× faster: cargo's
# downloaded crate index, git deps and incremental target dir survive
# across builds even though the layer above (COPY src/) invalidates the
# Docker layer cache. Mirrors the pattern manabrew-server's Dockerfile uses.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked \
    yarn build:web

# --- Website: landing page (manabrew.app) + docs (docs.manabrew.app),
# Astro + Starlight, two builds out of one package ---
FROM node:20-slim AS website

# The site imports assets and theme data via relative paths that escape
# website/ (../images, ../public, ../src) — keep the same directory layout here.
WORKDIR /repo/website
COPY website/package.json website/yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile
COPY images/ /repo/images/
COPY public/manabrew_brewery_1.png /repo/public/manabrew_brewery_1.png
COPY src/themes/ /repo/src/themes/
COPY src/assets/manaBrew.png /repo/src/assets/manaBrew.png
COPY website/ ./
RUN yarn build

# --- Runtime: Caddy serves the built dist directly, reverse-proxies the
# relay + parity hostnames, and terminates Let's Encrypt TLS for all
# three. ops/Caddyfile is mounted in via compose so config changes don't
# require a rebuild. ---
FROM caddy:2-alpine

COPY --from=builder /build/dist/ /srv/manabrew/
COPY --from=website /repo/website/dist/landing/ /srv/landing/
COPY --from=website /repo/website/dist/docs/ /srv/docs/

EXPOSE 80 443
