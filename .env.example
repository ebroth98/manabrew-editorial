# Deploy-host .env — sourced by deploy.sh and used for compose interpolation on
# the production / staging boxes. Copy to `.env` on the box and fill in. On the
# production host this file is the `ops/production.secrets` symlink; on the
# staging VM it is a real file. Values here override deploy.sh's built-in
# defaults. Nothing in this file is needed for local development.

# ──────────────────────────────────────────────────────────────────
# Core (required — production AND staging)
# ──────────────────────────────────────────────────────────────────

# Shared relay key: the relay's auth key AND the password the web app / hosted
# node use to reach it. Required by every compose stack.
MANABREW_SERVER_KEY=

# Optional second key accepted by the relay (key rotation / privileged clients).
SECRET_MANABREW_KEY=

# ──────────────────────────────────────────────────────────────────
# Staging hostnames (staging VM only)
# ──────────────────────────────────────────────────────────────────
# deploy-staging.sh already defaults DEPLOY_BRANCH=staging,
# COMPOSE_FILE=compose.staging.yml and MANABREW_IMAGE_TAG=staging, so those are
# not needed here — set one only to override for a one-off (e.g. deploy a
# different branch/tag to the box).

# Hostnames the staging edge serves (required on the staging box). Consumed by
# ops/staging.Caddyfile ({$...}, also drives ACME certs) and, via RELAY_HOST,
# the web runtime relay config. Must match the box's DNS. STAGING_API_HOST must
# also match the host in the STAGING_HUB_API_URL repo *variable* (baked into the
# web image at build time — set in GitHub, not here).
STAGING_APP_HOST=
STAGING_RELAY_HOST=
STAGING_API_HOST=

# ──────────────────────────────────────────────────────────────────
# Web feature flags (optional)
# ──────────────────────────────────────────────────────────────────

# Expose the Forge "Play vs AI" hosted-engine option (needs the self-hosted-node
# service running under the `hosted-ai` profile). Default true.
HOSTED_AI_ENABLED=true

# Set to 1 to expose the dev-only /design-system reference route on this build.
DESIGN_SYSTEM=

# ──────────────────────────────────────────────────────────────────
# Ingress auth hashes (optional — bcrypt, note the `$`; single-quote in shells)
# ──────────────────────────────────────────────────────────────────
# Leave these UNSET (commented) to get the Caddyfile's locked placeholder
# (route locked, not broken). Caddy's {$VAR:default} only falls back to the
# default when the var is unset — an EMPTY value (e.g. `HUB_ADMIN_PASSWORD_HASH=`)
# is passed through and crashes caddy with "username and password cannot be
# empty". So set a real hash (`caddy hash-password`) or keep it commented.

# Locks /admin/* on the deck hub (api / api-staging host).
# HUB_ADMIN_PASSWORD_HASH=

# Locks the pushgateway + loki ingress (observability profile only).
# PUSHGATEWAY_PASSWORD_HASH=

# ──────────────────────────────────────────────────────────────────
# Relay game-capture (optional)
# ──────────────────────────────────────────────────────────────────

# Cap for on-disk per-game zstd captures before rotation. Default 20.
MANABREW_GAME_CAPTURE_MAX_GB=20

# ──────────────────────────────────────────────────────────────────
# Hosted "Play vs AI" node tuning (optional — `hosted-ai` profile)
# ──────────────────────────────────────────────────────────────────

SELF_HOSTED_NODE_FORMAT=commander
SELF_HOSTED_NODE_MAX_PLAYERS=2
SELF_HOSTED_NODE_MAX_GAMES=1
SELF_HOSTED_NODE_METRICS_PUSH_URL=

# ──────────────────────────────────────────────────────────────────
# Observability stack (optional — enable with COMPOSE_PROFILES=observability)
# ──────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES may also live in manabrew-rs/crates/manabrew-server/.env
# (that file additionally carries the `parity` dashboard toggle). Accepts a
# comma list, e.g. `observability` or `observability,parity`.

COMPOSE_PROFILES=
GRAFANA_ADMIN_PASSWORD=
DISCORD_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────────
# Git pull (optional — avoids public GitHub rate limits on deploy.sh's pull)
# ──────────────────────────────────────────────────────────────────

GITHUB_TOKEN=
GITHUB_REPO=witchesofthehill/manabrew

# ──────────────────────────────────────────────────────────────────
# Standalone single-box self-host only (compose.selfhost.yml / deploy-local.sh)
# ──────────────────────────────────────────────────────────────────
# Not used by the production/staging deploy above — only the self-contained
# standalone stack, which points the app at its own relay via these.

RELAY_HOST=
RELAY_PORT=443
RELAY_PASSWORD=
WEB_PORT=8080
