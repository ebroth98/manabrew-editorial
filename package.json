{
  "name": "manabrew",
  "private": true,
  "version": "1.5.2",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "release:plan": "cargo xtask plan",
    "gen:manifest": "cargo xtask manifest",
    "tauri": "tauri",
    "dev": "tauri dev",
    "android": "node scripts/mobile-dev.mjs android dev",
    "android:init": "node scripts/mobile-dev.mjs android init",
    "android:build": "node scripts/mobile-dev.mjs android build",
    "ios": "node scripts/mobile-dev.mjs ios dev",
    "ios:init": "node scripts/mobile-dev.mjs ios init",
    "ios:build": "node scripts/mobile-dev.mjs ios build",
    "dev:relay": "cargo run --release -p manabrew-server",
    "dev:forge": "yarn build:harness && ./forge-harness/build-native.sh && yarn ensure:wasm && tauri dev --features forge-room",
    "dev:forge:win": "yarn build:harness && pwsh -File ./forge-harness/build-native.ps1 && yarn ensure:wasm && tauri dev --features forge-room",
    "build": "tauri build",
    "web": "yarn gen:protocol && node scripts/ensure-wasm.mjs && vite",
    "ensure:wasm": "node scripts/ensure-wasm.mjs",
    "ensure:harness": "node scripts/harness.mjs ensure",
    "gen:protocol": "cargo run -q -p manabrew-protocol --bin gen-protocol -- src/protocol && prettier --write src/protocol",
    "gen:protocol-docs": "yarn gen:protocol && node scripts/gen-protocol-doc-types.mjs",
    "vite:dev": "yarn gen:protocol && vite",
    "vite:build": "yarn gen:protocol && tsc -b && vite build",
    "tauri:before-build": "yarn build:harness && yarn vite:build",
    "pretypecheck": "yarn gen:protocol",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "pretest": "yarn gen:protocol",
    "lint": "eslint . && prettier --check src && yarn typecheck",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --workspace --lib --bins -- -D warnings",
    "lint:all": "yarn lint && yarn lint:rust",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "format:all": "prettier --write src && cargo fmt --all",
    "fix:all": "eslint . --fix && prettier --write src && cargo fmt --all && yarn typecheck",
    "preview": "vite preview",
    "build:harness": "node scripts/harness.mjs build",
    "parity": "node scripts/parity.mjs",
    "parity:gui": "cargo run -p parity-debugger",
    "parity:test": "node scripts/harness.mjs ensure && cargo run --profile parity -p parity --bin parity -- --java-jar forge-harness/target/forge-harness-jar-with-dependencies.jar",
    "scan": "node scan_structure.cjs",
    "import-deck": "tsx scripts/import-deck.ts",
    "enrich-presets": "node scripts/enrich-preset-decks.mjs",
    "format-engine": "cargo fmt --manifest-path Cargo.toml -p forge-foundation -p forge-carddb -pmanabrew-engine  -p manabrew-server -p parity -p wasm -p manabrew-agent-interface",
    "test:manabrew-engine": "cargo test --release -pmanabrew-engine  --lib --test cards",
    "test:networking": "cargo build -p manabrew-server -p self-hosted-node && cargo test -p networking-tests --test networking_regression -- --ignored --nocapture --test-threads=1",
    "build:wasm": "node scripts/build-wasm.mjs",
    "dev:web": "yarn gen:protocol && yarn ensure:wasm && vite",
    "website:dev": "npm --prefix website run dev",
    "website:dev:docs": "npm --prefix website run dev:docs",
    "website:build": "npm --prefix website run build",
    "build:web": "yarn gen:protocol && yarn build:wasm && tsc -b && vite build",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt --edition 2021"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@fontsource/alegreya-sans": "^5.2.5",
    "@fontsource/cormorant-garamond": "^5.2.5",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query": "^5.100.5",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.574.0",
    "next-themes": "^0.4.6",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.6.4",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.1",
    "@iconify-json/game-icons": "^1.2.3",
    "@iconify/utils": "^3.1.0",
    "@redux-devtools/core": "^5.0.0",
    "@redux-devtools/dock-monitor": "^5.0.0",
    "@redux-devtools/inspector-monitor": "^7.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "redux": "^5.0.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  },
  "resolutions": {
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  }
}
