{
  "name": "forge-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "vite:dev": "vite",
    "vite:build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "preview": "vite preview",
    "ios": "tauri ios dev",
    "android": "tauri android dev",
    "ios-build": "tauri ios build",
    "android-build": "tauri android build",
    "build:harness": "node scripts/harness.mjs build",
    "parity": "node scripts/parity.mjs",
    "parity:test": "node scripts/harness.mjs ensure && cargo run -p forge-parity --bin forge-parity -- --java-jar forge/forge-harness/target/forge-harness-jar-with-dependencies.jar",
    "audit:prompts": "node scripts/audit-prompt-contract.mjs",
    "scan": "node scan_structure.cjs",
    "import-deck": "tsx scripts/import-deck.ts",
    "format-engine": "cargo fmt --manifest-path Cargo.toml -p forge-foundation -p forge-carddb -p forge-engine-core -p forge-server -p forge-parity -p forge-wasm -p forge-agent-interface",
    "test:forge-engine": "cargo test --release -p forge-engine-core --lib --test cards",
    "build:wasm": "node scripts/build-wasm.mjs",
    "dev:web": "npm run build:wasm && vite",
    "build:web": "npm run build:wasm && tsc -b && vite build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2.5.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "next-themes": "^0.4.6",
    "pixi.js": "^8.18.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.6.4",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@iconify-json/game-icons": "^1.2.3",
    "@iconify/utils": "^3.1.0",
    "@redux-devtools/core": "^5.0.0",
    "@redux-devtools/dock-monitor": "^5.0.0",
    "@redux-devtools/inspector-monitor": "^7.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "redux": "^5.0.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1"
  }
}
