# Git & CI
.git/
.github/
.gitignore

# Ironsmith submodule: the web image compiles its WASM from source (Dockerfile.web
# `ironsmith` stage), so send the sources but not build output, deps, or the
# large card data it re-downloads during the build.
ironsmith/pkg/
ironsmith/reports/
ironsmith/cards.json
ironsmith/cards.json.*
ironsmith/**/node_modules/
ironsmith/**/target/
ironsmith/**/dist/

# Rust build artifacts
target/
src-tauri/target/

# Node / Tauri dev artifacts
node_modules/
dist/

# IDE & OS
.DS_Store
*.swp
.idea/
.vscode/

# Database & logs
parity.db
*.log

# Documentation (not needed in image)
*.md

# Unused forge modules (not needed for forge-harness build)
forge/forge-gui-desktop/
forge/forge-gui-mobile/
forge/forge-gui-mobile-dev/
forge/forge-gui-ios/
forge/forge-gui-android/
forge/forge-installer/
forge/forge-lda/
forge/adventure-editor/

# Website (built in its own Docker stage)
website/node_modules/
website/dist/
website/.astro/
